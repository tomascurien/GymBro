# --- CONFIGURACIÓN DE BASE DE DATOS (SUPABASE / POSTGRES) ---

# Nombre de la base (por defecto en Supabase es 'postgres')
DB_NAME=postgres

# Usuario de la base
DB_USER=postgres.xxxxxxxxxxxxxxxx

# Contraseña de la base (NO es la de login de Supabase)
DB_PASSWORD=tu_password_de_la_base

# Host que da Supabase (ej: aws-1-sa-east-1.pooler.supabase.com)
DB_HOST=tu-host.pooler.supabase.com

# Puerto estándar de PostgreSQL
DB_PORT=5432

# --- SERVIDOR ---
PORT=3001

# Clave para firmar los tokens JWT: poné una frase larga y aleatoria
SECRET_KEY=cambia_esto_por_una_clave_larga_y_secreta

# --- SUPABASE STORAGE ---
SUPABASE_URL=https://tu-proyecto-id.supabase.co
# Usá la clave 'service_role' (NO la 'anon'/'public') para el backend
SUPABASE_KEY=tu_service_role_key
